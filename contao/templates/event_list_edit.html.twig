{% if header %}
    <div class="header{{ classHeader }}">
        <time datetime="{{ datetime }}" class="date">{{ firstDate }}</time>{% if firstDay %} <span class="day">
            ({{ firstDay }})</span>{% endif %}
    </div>
{% endif %}

<div class="event layout_list{{ classList }}">
    <h2><a href="{{ href }}"
           title="{{ title }} ({% if day %}{{ day }}, {% endif %}{{ date }}{% if time %}, {{ time }}{% endif %})"{{ target|raw }}>{{ link }}</a>
    </h2>

    {% if time or span %}
        <p class="time">{{ time }}{{ span }}</p>
    {% endif %}

    <div class="ce_text block">
        {{ details|raw }}
        {% if editRef %}
            <p class="editlink"><a href="{{ editRef }}" title="{{ editTitle }}"> {{ editLabel }} </a></p>
        {% endif %}
    </div>
</div>
