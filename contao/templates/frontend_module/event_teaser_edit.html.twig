{% block event_container %}
    <div class="event layout_teaser{{ classList|default('') }}">
    {{ block('event_header') }}
    {{ block('event_title') }}

        {% if (time is defined and time) or (span is defined and span) %}
        {{ block('event_time') }}
    {% endif %}

        {% if location is defined and location %}
        {{ block('event_location') }}
    {% endif %}

    {{ block('event_teaser') }}

        {% if details is defined and details %}
        {{ block('read_more') }}
    {% endif %}

        {% if editRef is defined and editRef %}
        {{ block('edit_link') }}
    {% endif %}
</div>
{% endblock %}

{% block event_header %}
    {% if header is defined and header %}
        <div class="header{{ classHeader|default('') }}">
            <span class="date">{{ firstDate|default('') }}</span>{% if firstDay is defined and firstDay %} <span
                    class="day">
                ({{ firstDay }})</span>{% endif %}
        </div>
    {% endif %}
{% endblock %}

{% block event_title %}
    {% if details is defined and details %}
        <h2><a href="{{ href|default('') }}"
               title="{{ title|default('') }} ({% if day is defined and day %}{{ day }}, {% endif %}{{ date|default('') }}{% if time is defined and time %}, {{ time }}{% endif %})"{{ target|default('')|raw }}>{{ link|default('') }}</a>
        </h2>
    {% else %}
        <h2>{{ title|default('') }}</h2>
    {% endif %}
{% endblock %}

{% block event_time %}
    <p class="time">{{ time|default('') }}{{ span|default('') }}</p>
{% endblock %}

{% block event_location %}
    <p class="location">{{ locationLabel|default('') }}: {{ location|default('') }}</p>
{% endblock %}

{% block event_teaser %}
    <div class="teaser">
        {{ teaser|default('')|raw }}
    </div>
{% endblock %}

{% block read_more %}
    <p class="more"><a href="{{ href|default('') }}"
                       title="{{ readMore|default('') }}"{{ target|default('')|raw }}>{{ more|default('') }} <span
                    class="invisible">{{ link|default('') }}</span></a></p>
{% endblock %}

{% block edit_link %}
    <p class="editlink"><a href="{{ editRef|default('') }}"
                           title="{{ editTitle|default('') }}"> {{ editLabel|default('') }} </a></p>
{% endblock %}
