{% extends "@Contao/frontend_module/_base.html.twig" %}

{% block content %}
    {{ block('info_message') }}
    {{ block('current_action') }}
    {{ block('action_list') }}
    {{ block('form_container') }}
{% endblock %}

{% block info_message %}
    <p class="error">
        {{ InfoMessage }}
    </p>
{% endblock %}

{% block current_action %}
    <h2>{{ 'MSC.caledit_currentActionEdit'|trans({}, 'contao_default') }}</h2>

    <p class="caledit_info">
        {% if CurrentEventLink %}
            <span class="date"> {{ CurrentDate }}: </span><span class="title">{{ CurrentTitle }}</span>
            <span class="caledit_publishinfo"> ({{ CurrentPublishedInfo }}) </span>
        {% else %}
            <span class="caledit_publishinfo"> ({{ CurrentPublishedInfo }}) </span>
        {% endif %}
    </p>
{% endblock %}

{% block action_list %}
    {% if deleteRef or cloneRef or editRef or CurrentEventLink %}
        <ul class="CalendarEditActionList">
            {% if CurrentEventLink %}
                <li class="viewlink"><a href="{{ CurrentEventLink }}"
                                        title="{{ CurrentTitle }}"> {{ 'MSC.caledit_viewLabel'|trans({}, 'contao_default') }} </a>
                </li>
            {% endif %}
            {% if editRef %}
                <li class="editlink"><a href="{{ editRef }}" title="{{ editTitle }}"> {{ editLabel }} </a></li>
            {% endif %}
            {% if cloneRef %}
                <li class="clonelink"><a href="{{ cloneRef }}" title="{{ cloneTitle }}"> {{ cloneLabel }} </a></li>
            {% endif %}
            {% if deleteRef %}
                <li class="deletelink"><a href="{{ deleteRef }}" title="{{ deleteTitle }}"> {{ deleteLabel }} </a></li>
            {% endif %}
        </ul>
    {% endif %}
{% endblock %}

{% block form_container %}
    {% if not fields %}
        <h2>{{ 'MSC.caledit_InsertEventData'|trans({}, 'contao_default') }}</h2>
        <p class="error">{{ FatalError }}</p>
    {% else %}
        <div class="event{{ classList }}">
            <h2>{{ 'MSC.caledit_InsertEventData'|trans({}, 'contao_default') }}</h2>

            {% if ContentWarning %}
                <p class="CalendarEditWarning"> {{ ContentWarning }} </p>
            {% endif %}

            {% if ImageWarning %}
                <p class="CalendarEditWarning"> {{ ImageWarning }} </p>
            {% endif %}

            <div class="formbody">
                {{ block('event_form') }}
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block event_form %}
    <form action="{{ action }}" method="post">
        <input type="hidden" name="FORM_SUBMIT" value="caledit_submit"/>
        {{ messages|raw }}
        <input type="hidden" name="REQUEST_TOKEN" value="{{ requestToken }}">
        <table cellpadding="2" cellspacing="2" border="0">
            <tbody>
            {{ block('event_fields') }}
            {{ block('submit_container') }}
            </tbody>
        </table>
    </form>
{% endblock %}

{% block event_fields %}
    {% for name, objWidget in fields %}
        {% if name != 'captcha' and name != 'published' and name != 'saveAs' and name != 'jumpToSelection' %}
            <tr>
                <td class="label">{{ objWidget.generateLabel()|raw }}</td>
                <td class="value">{{ objWidget.generateWithError()|raw }}</td>
            </tr>
        {% endif %}
    {% endfor %}

    {% if fields.published %}
        <tr>
            <td class="label">&nbsp;</td>
            <td class="value">{{ fields.published.generateWithError()|raw }}</td>
        </tr>
    {% endif %}

    {% if fields.saveAs %}
        <tr>
            <td class="label">&nbsp;</td>
            <td class="value">{{ fields.saveAs.generateWithError()|raw }}</td>
        </tr>
    {% endif %}

    {% if fields.captcha %}
        {{ fields.captcha.parse()|raw }}
    {% endif %}

    {% if fields.jumpToSelection %}
        <tr>
            <td class="label">{{ fields.jumpToSelection.generateLabel()|raw }}</td>
            <td class="value">{{ fields.jumpToSelection.generateWithError()|raw }}</td>
        </tr>
    {% endif %}
{% endblock %}

{% block submit_container %}
    <tr>
        <td class="label">&nbsp;</td>
        <td class="value"><input type="submit" class="submit" value="{{ submit }}"/></td>
    </tr>
{% endblock %}
