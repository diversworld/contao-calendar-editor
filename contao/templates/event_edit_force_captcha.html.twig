{% extends "@Contao/frontend_module/_base.html.twig" %}

{% block content %}
    {{ block('info_message') }}
    {{ block('current_action') }}
    {{ block('action_list') }}
    {{ block('form_container') }}
{% endblock %}

{% block info_message %}
    <p class="error">
        {{ InfoMessage|default('') }}
    </p>
{% endblock %}

{% block current_action %}
    <h2>{{ 'MSC.caledit_currentActionEdit'|trans({}, 'contao_default') }}</h2>

    <p class="caledit_info">
        {% if CurrentEventLink is defined and CurrentEventLink %}
            <span class="date"> {{ CurrentDate|default('') }}: </span><span
                class="title">{{ CurrentTitle|default('') }}</span>
            <span class="caledit_publishinfo"> ({{ CurrentPublishedInfo|default('') }}) </span>
        {% else %}
            <span class="caledit_publishinfo"> ({{ CurrentPublishedInfo|default('') }}) </span>
        {% endif %}
    </p>
{% endblock %}

{% block action_list %}
    {% if (deleteRef is defined and deleteRef) or (cloneRef is defined and cloneRef) or (editRef is defined and editRef) or (CurrentEventLink is defined and CurrentEventLink) %}
        <ul class="CalendarEditActionList">
            {% if CurrentEventLink is defined and CurrentEventLink %}
                <li class="viewlink"><a href="{{ CurrentEventLink }}"
                                        title="{{ CurrentTitle|default('') }}"> {{ 'MSC.caledit_viewLabel'|trans({}, 'contao_default') }} </a>
                </li>
            {% endif %}
            {% if editRef is defined and editRef %}
                <li class="editlink"><a href="{{ editRef }}"
                                        title="{{ editTitle|default('') }}"> {{ editLabel|default('') }} </a></li>
            {% endif %}
            {% if cloneRef is defined and cloneRef %}
                <li class="clonelink"><a href="{{ cloneRef }}"
                                         title="{{ cloneTitle|default('') }}"> {{ cloneLabel|default('') }} </a></li>
            {% endif %}
            {% if deleteRef is defined and deleteRef %}
                <li class="deletelink"><a href="{{ deleteRef }}"
                                          title="{{ deleteTitle|default('') }}"> {{ deleteLabel|default('') }} </a></li>
            {% endif %}
        </ul>
    {% endif %}
{% endblock %}

{% block form_container %}
    {% if fields is not defined or not fields %}
        <h2>{{ 'MSC.caledit_InsertEventData'|trans({}, 'contao_default') }}</h2>
        <p class="error">{{ FatalError|default('') }}</p>
    {% else %}
        <div class="event{{ classList|default('') }}">
            <h2>{{ 'MSC.caledit_InsertEventData'|trans({}, 'contao_default') }}</h2>

            {% if ContentWarning is defined and ContentWarning %}
                <p class="CalendarEditWarning"> {{ ContentWarning }} </p>
            {% endif %}

            {% if ImageWarning is defined and ImageWarning %}
                <p class="CalendarEditWarning"> {{ ImageWarning }} </p>
            {% endif %}

            <div class="formbody">
                {{ block('event_form') }}
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block event_form %}
    <form action="{{ action|default('') }}" method="post">
        <input type="hidden" name="FORM_SUBMIT" value="caledit_submit"/>
        {{ messages|default('')|raw }}
        <input type="hidden" name="REQUEST_TOKEN" value="{{ requestToken|default('') }}">
        <table cellpadding="2" cellspacing="2" border="0">
            <tbody>
            {{ block('event_fields') }}
            {{ block('submit_container') }}
            </tbody>
        </table>
    </form>
{% endblock %}

{% block event_fields %}
    {% for name, objWidget in fields|default([]) %}
        {% if name != 'captcha' and name != 'published' and name != 'saveAs' and name != 'jumpToSelection' %}
            <tr>
                <td class="label">{{ objWidget.generateLabel()|raw }}</td>
                <td class="value">{{ objWidget.generateWithError()|raw }}</td>
            </tr>
        {% endif %}
    {% endfor %}

    {% if fields.published is defined and fields.published %}
        <tr>
            <td class="label">&nbsp;</td>
            <td class="value">{{ fields.published.generateWithError()|raw }}</td>
        </tr>
    {% endif %}

    {% if fields.saveAs is defined and fields.saveAs %}
        <tr>
            <td class="label">&nbsp;</td>
            <td class="value">{{ fields.saveAs.generateWithError()|raw }}</td>
        </tr>
    {% endif %}

    {% if fields.captcha is defined and fields.captcha %}
        {{ fields.captcha.parse()|raw }}
    {% endif %}

    {% if fields.jumpToSelection is defined and fields.jumpToSelection %}
        <tr>
            <td class="label">{{ fields.jumpToSelection.generateLabel()|raw }}</td>
            <td class="value">{{ fields.jumpToSelection.generateWithError()|raw }}</td>
        </tr>
    {% endif %}
{% endblock %}

{% block submit_container %}
    <tr>
        <td class="label">&nbsp;</td>
        <td class="value"><input type="submit" class="submit" value="{{ submit|default('') }}"/></td>
    </tr>
{% endblock %}
